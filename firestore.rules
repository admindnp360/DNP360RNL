rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ────────────────────────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    // Safe role lookup — returns null if user doc doesn't exist (e.g. anonymous)
    function callerRole() {
      return isSignedIn()
          && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role
        : null;
    }

    function isAdmin()      { return callerRole() == 'admin'; }
    function isOfficial()   { return callerRole() == 'official'; }
    function isSafaikarmi() { return callerRole() == 'safaikarmi'; }

    function isAdminOrOfficial() { return isAdmin() || isOfficial(); }
    function isStaff()           { return isAdmin() || isOfficial() || isSafaikarmi(); }

    // Super Admin guard — protects the SUPERADMIN doc and any doc with isSuperAdmin=true
    function isSuperAdminDoc(docId) {
      return docId == 'SUPERADMIN'
        || (resource != null && resource.data.get('isSuperAdmin', false) == true);
    }

    // ── All reads are open ─────────────────────────────────────────────────────
    // The app enforces its own role-based UI; reads are non-sensitive municipal
    // data. Writes still require a valid Firebase Auth token.
    match /{document=**} {
      allow read: if true;
    }

    // ── Schema version / metadata ──────────────────────────────────────────────
    match /meta/{docId} {
      allow write: if isSignedIn();
    }

    // ── Users ──────────────────────────────────────────────────────────────────
    // SUPERADMIN document can NEVER be deleted by anyone.
    match /users/{userId} {
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      // Super admin cannot be deleted — by anyone, ever.
      allow delete: if isSignedIn() && !isSuperAdminDoc(userId);
    }

    // Mobile → UID lookup
    match /usersByMobile/{mobile} {
      allow write: if isSignedIn();
    }

    // ── Houses ─────────────────────────────────────────────────────────────────
    // Any signed-in user with app access can write (UI enforces role restrictions)
    match /houses/{houseId} {
      allow write: if isSignedIn();
    }

    // ── Wards ──────────────────────────────────────────────────────────────────
    match /wards/{wardId} {
      allow write: if isSignedIn();
    }

    // ── Groups ─────────────────────────────────────────────────────────────────
    match /groups/{groupId} {
      allow write: if isSignedIn();
    }

    // ── Notices ────────────────────────────────────────────────────────────────
    match /notices/{noticeId} {
      allow write: if isSignedIn();
    }

    // ── Complaints ─────────────────────────────────────────────────────────────
    match /complaints/{complaintId} {
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete:  if isSignedIn();
    }

    // ── Attendance ─────────────────────────────────────────────────────────────
    match /attendance/{attendanceId} {
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete:  if isSignedIn();
    }

    // ── House Visits ───────────────────────────────────────────────────────────
    match /houseVisits/{visitId} {
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete:  if isSignedIn();
    }

    // ── Secret Keys ────────────────────────────────────────────────────────────
    match /secretKeys/{keyId} {
      allow write: if isSignedIn();
    }

    // ── Settings ───────────────────────────────────────────────────────────────
    match /settings/{docId} {
      allow write: if isSignedIn();
    }

    // ── Password Reset Requests ────────────────────────────────────────────────
    match /passwordResetRequests/{reqId} {
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete:  if isSignedIn();
    }

    // ── Import History ─────────────────────────────────────────────────────────
    match /importHistory/{histId} {
      allow write: if isSignedIn();
    }

  }
}
